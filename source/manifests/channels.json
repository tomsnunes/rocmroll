{
  "stable": {
    "description": "Pinned AMD-recommended ROCm 7.2.1 profile with stable ComfyUI release",
    "defaultProfile": "stable",
    "comfyui": {
      "source": "git",
      "repo": "https://github.com/Comfy-Org/ComfyUI.git",
      "ref": "v0.24.0",
      "pinCommit": null
