{
  "stable": {
    "description": "Pinned AMD-recommended ROCm 7.2.1 profile with stable ComfyUI release",
    "defaultProfile": "stable",
    "comfyui": {
      "source": "git",
      "repo": "https://github.com/Comfy-Org/ComfyUI.git",
      "ref": "v0.27.0",
      "pinCommit": null
    },
    "python": {
      "version": "3.12.10"
    },
    "rocm": {
      "source": "directUrls",
      "version": "7.2.1",
      "torchVersion": "2.9.1+rocm7.2.1",
      "torchvisionVersion": "0.24.1+rocm7.2.1",
      "torchaudioVersion": "2.9.1+rocm7.2.1",
      "pythonTag": "cp312",
      "allowPreRelease": false,
      "directUrls": {
        "sdk": [
          "https://repo.radeon.com/rocm/windows/rocm-rel-7.2.1/rocm_sdk_core-7.2.1-py3-none-win_amd64.whl",
          "https://repo.radeon.com/rocm/windows/rocm-rel-7.2.1/rocm_sdk_devel-7.2.1-py3-none-win_amd64.whl",
          "https://repo.radeon.com/rocm/windows/rocm-rel-7.2.1/rocm_sdk_libraries_custom-7.2.1-py3-none-win_amd64.whl",
          "https://repo.radeon.com/rocm/windows/rocm-rel-7.2.1/rocm-7.2.1.tar.gz"
        ],
        "torch": [
          "https://repo.radeon.com/rocm/windows/rocm-rel-7.2.1/torch-2.9.1+rocm7.2.1-cp312-cp312-win_amd64.whl",
          "https://repo.radeon.com/rocm/windows/rocm-rel-7.2.1/torchvision-0.24.1+rocm7.2.1-cp312-cp312-win_amd64.whl",
          "https://repo.radeon.com/rocm/windows/rocm-rel-7.2.1/torchaudio-2.9.1+rocm7.2.1-cp312-cp312-win_amd64.whl"
        ]
      }
    },
    "packages": {
      "tritonWindows": "3.7.1.post27",
      "sageAttention": "1.0.6"
    }
  },
  "preview": {
    "description": "Promoted ROCm from AMD's unified whl-multi-arch index and latest ComfyUI master.",
    "defaultProfile": "optimized",
    "comfyui": {
      "source": "git",
      "repo": "https://github.com/Comfy-Org/ComfyUI.git",
      "ref": "master",
      "pinCommit": null
    },
    "python": {
      "version": "3.12.10"
    },
    "rocm": {
      "source": "multiArch",
      "indexUrl": "https://rocm.nightlies.amd.com/whl-multi-arch/",
      "allowPreRelease": true,
      "torchPackages": [
        "torch[device-{device}]",
        "torchvision[device-{device}]",
        "torchaudio"
      ],
      "rocmPackages": [
        "rocm[libraries,devel,device-{device}]"
      ],
      "torchDependencies": [
        "filelock",
        "fsspec",
        "jinja2",
        "mpmath==1.3.0",
        "networkx",
        "numpy",
        "pillow",
        "setuptools<82",
        "sympy",
        "typing-extensions"
      ]
    },
    "packages": {
      "tritonWindows": "3.7.1.post27",
      "sageAttention": "1.0.6"
    }
  },
  "nightly": {
    "description": "Staging ROCm from AMD's whl-staging-multi-arch index and latest ComfyUI master. More cutting-edge and more volatile than preview.",
