{
  "name": "performance-autotune",
  "description": "Aggressive ROCm kernel autotuning profile. Enables MIOpen and Triton autotuning to find optimal kernel configurations for your specific GPU and workload. WARNING: The first run will be significantly slower while kernels are benchmarked and cached. Subsequent runs will use the cached results and run faster. Best run once on a representative workload, then switch to the optimized profile.",
  "version": "1.0",
  "defaultForChannels": [],
  "env": {
    "COMFYUI_ENABLE_MIOPEN": "1",
    "FLASH_ATTENTION_TRITON_AMD_ENABLE": "TRUE",
    "FLASH_ATTENTION_TRITON_AMD_AUTOTUNE": "TRUE",
    "MIOPEN_FIND_ENFORCE": "1",
    "MIOPEN_FIND_MODE": "1",
    "MIOPEN_DEBUG_DISABLE_FIND_DB": "0",
    "MIOPEN_SEARCH_CUTOFF": "100",
    "MIOPEN_ENABLE_LOGGING": "0",
    "MIOPEN_LOG_LEVEL": "0",
    "MIOPEN_ENABLE_LOGGING_CMD": "0",
    "TRITON_PRINT_AUTOTUNING": "1",
    "TRITON_CACHE_AUTOTUNING": "1",
    "PYTORCH_TUNABLEOP_ENABLED": "1",
    "PYTORCH_MIOPEN_SUGGEST_NHWC": "1",
    "PYTHONUNBUFFERED": "1",
    "PYTHONIOENCODING": "utf-8",
    "PYTHONUTF8": "1"
  },
  "launchArgs": [
    "--disable-api-nodes",
    "--disable-smart-memory",
    "--disable-pinned-memory",
    "--preview-method", "auto",
    "--use-sage-attention",
    "--enable-manager-legacy-ui",
    "--enable-dynamic-vram"
  ],
  "legacyGpuOverrides": {
    "env": {
      "TORCH_BACKENDS_CUDA_FLASH_SDP_ENABLED": "0",
      "TORCH_BACKENDS_CUDA_MEM_EFF_SDP_ENABLED": "0",
      "TORCH_BACKENDS_CUDA_MATH_SDP_ENABLED": "1"
    },
    "launchArgs": [
      "--use-quad-cross-attention"
    ]
  }
}
